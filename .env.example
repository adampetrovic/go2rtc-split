# HTTP server
PORT=8080
HOST=0.0.0.0
BASE_PATH=/split

# UI
APP_NAME="go2rtc Split"
PAGE_TITLE="go2rtc Split"
LAYOUT=auto
OBJECT_FIT=contain

# Streams: comma format "stream:Label,stream2:Label" or JSON array
GO2RTC_STREAMS=stream_a:Stream A,stream_b:Stream B

# Same-origin go2rtc by default. When hosted at https://go2rtc.example/split/ this connects to /api/ws.
GO2RTC_WS_PATH=/api/ws
GO2RTC_STREAM_PARAM=src
# GO2RTC_WS_URL=wss://go2rtc.example/api/ws?src={src}
# GO2RTC_QUERY=media=video+audio

# Audio and playback
AUDIO_MODE=mixed
START_MUTED=false
DEFAULT_VOLUME=1
AUDIO_METERS=true
AUDIO_UNLOCK_PROMPT=true
NATIVE_VIDEO_CONTROLS=false

# Behaviour
SHOW_CONTROLS=true
SHOW_STATUS=true
WAKE_LOCK=true
SLEEP_RECOVERY=true
SLEEP_RECOVERY_RECONNECT_MS=30000
FULLSCREEN_BUTTON=true
DOCUMENT_FULLSCREEN_BUTTON=true
STREAM_FULLSCREEN_BUTTON=true
RECONNECT_MIN_MS=1000
RECONNECT_MAX_MS=15000
ICE_SERVERS=stun:stun.cloudflare.com:3478,stun:stun.l.google.com:19302
